# Copier ce fichier en .env.local et remplir les valeurs

# Supabase - disponible dans Settings > API de votre projet
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mot de passe admin (choisissez quelque chose de robuste)
ADMIN_PASSWORD=votre_mot_de_passe_secret
